---
import { getCollection, type CollectionEntry } from 'astro:content';
import LessonLayout from '../../../layouts/LessonLayout.astro';
import { stripLocaleSlug, type Locale } from '../../../i18n';

type Lesson = CollectionEntry<'lessons'>;
const LOCALE: Locale = 'de';

export async function getStaticPaths() {
  const all = await getCollection('lessons', ({ data }) => !data.draft);
  const lessons = all.filter((e) => e.slug.startsWith('de/'));

  const byTrack = new Map<Lesson['data']['track'], Lesson[]>();
  for (const lesson of lessons) {
    const list = byTrack.get(lesson.data.track) ?? [];
    list.push(lesson);
    byTrack.set(lesson.data.track, list);
  }
  for (const list of byTrack.values()) {
    list.sort((a, b) => a.data.order - b.data.order);
  }

  return lessons.map((lesson) => {
    const siblings = byTrack.get(lesson.data.track) ?? [];
    const idx = siblings.findIndex((s) => s.slug === lesson.slug);
    const prev = idx > 0 ? siblings[idx - 1] : null;
    const next = idx >= 0 && idx < siblings.length - 1 ? siblings[idx + 1] : null;

    return {
      params: { slug: stripLocaleSlug(lesson.slug) },
      props: { lesson, siblings, prev, next },
    };
  });
}

interface Props {
  lesson: Lesson;
  siblings: Lesson[];
  prev: Lesson | null;
  next: Lesson | null;
}

const { lesson, siblings, prev, next } = Astro.props as Props;
const { Content, headings } = await lesson.render();
---

<LessonLayout
  lesson={lesson}
  siblings={siblings}
  prev={prev}
  next={next}
  headings={headings}
  locale={LOCALE}
>
  <Content />
</LessonLayout>

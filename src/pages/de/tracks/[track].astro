---
import { getCollection, type CollectionEntry } from 'astro:content';
import LanguageSwitcher from '../../../components/LanguageSwitcher.astro';
import ThemeBoot from '../../../components/ThemeBoot.astro';
import ThemeToggle from '../../../components/ThemeToggle.astro';
import {
  localizedAboutHref,
  localizedLessonHref,
  localizedRootHref,
  stripLocaleSlug,
  t,
  type Locale,
} from '../../../i18n';

type TrackSlug = CollectionEntry<'lessons'>['data']['track'];

const trackTitleKeys: Record<TrackSlug, string> = {
  'it-basics': 'track.itBasics.title',
  'artificial-intelligence': 'track.ai.title',
  'programming': 'track.programming.title',
};
const trackDescriptionKeys: Record<TrackSlug, string> = {
  'it-basics': 'track.itBasics.description',
  'artificial-intelligence': 'track.ai.description',
  'programming': 'track.programming.description',
};

export async function getStaticPaths() {
  const all = await getCollection('lessons', ({ data }) => !data.draft);
  const lessons = all.filter((e) => e.slug.startsWith('de/'));
  const byTrack = new Map<TrackSlug, CollectionEntry<'lessons'>[]>();
  for (const lesson of lessons) {
    const list = byTrack.get(lesson.data.track) ?? [];
    list.push(lesson);
    byTrack.set(lesson.data.track, list);
  }

  return [...byTrack.entries()].map(([track, items]) => ({
    params: { track },
    props: { lessons: items },
  }));
}

const locale: Locale = 'de';
const { track } = Astro.params as { track: TrackSlug };
const { lessons } = Astro.props as { lessons: CollectionEntry<'lessons'>[] };
const title = t(trackTitleKeys[track], locale);
const description = t(trackDescriptionKeys[track], locale);

/*
 * Group lessons by curriculum module via order range; see the English
 * track page for the rationale (CLAUDE.md defines the boundaries).
 */
function moduleKeyForOrder(order: number): string {
  if (order >= 1 && order <= 8) return 'module-1';
  if (order >= 9 && order <= 14) return 'module-2';
  if (order >= 15 && order <= 26) return 'module-3';
  return '_general';
}

const moduleTitleKeys: Record<string, string> = {
  'module-1': 'trackPage.module1Title',
  'module-2': 'trackPage.module2Title',
  'module-3': 'trackPage.module3Title',
  '_general': 'trackPage.moduleGeneral',
};

const grouped = lessons.reduce<Record<string, CollectionEntry<'lessons'>[]>>((acc, lesson) => {
  const key = moduleKeyForOrder(lesson.data.order);
  (acc[key] ||= []).push(lesson);
  return acc;
}, {});

for (const key of Object.keys(grouped)) {
  grouped[key].sort((a, b) => a.data.order - b.data.order);
}

const moduleOrder = Object.entries(grouped)
  .map(([key, items]) => ({
    key,
    title: t(moduleTitleKeys[key] ?? 'trackPage.moduleGeneral', locale),
    firstOrder: items[0].data.order,
    items,
  }))
  .sort((a, b) => a.firstOrder - b.firstOrder);
---

<!doctype html>
<html lang={locale} class="bg-apple-bg text-apple-text antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — {t('nav.home', locale)}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeBoot />
  </head>
  <body class="min-h-screen font-sans">
    <header class="border-b border-apple-border/60 bg-apple-bg/80 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href={localizedRootHref(locale)} class="text-base font-semibold tracking-tight text-apple-text">
          {t('nav.home', locale)}
        </a>
        <div class="flex items-center gap-6">
          <a
            href={localizedAboutHref(locale)}
            class="text-sm text-apple-text-secondary transition-colors duration-300 hover:text-apple-text motion-reduce:transition-none"
          >
            {t('nav.about', locale)}
          </a>
          <LanguageSwitcher currentLocale={locale} currentPath={Astro.url.pathname} />
          <ThemeToggle locale={locale} />
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-3xl px-6 pt-20 pb-24 sm:pt-24">
      <a
        href={localizedRootHref(locale)}
        class="mb-8 inline-flex items-center gap-1 text-sm text-apple-text-secondary transition-colors duration-300 hover:text-apple-text motion-reduce:transition-none"
      >
        <span aria-hidden="true">←</span> {t('trackPage.allTracks', locale)}
      </a>

      <h1 class="text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl">{title}</h1>
      <p class="mt-6 max-w-2xl text-xl leading-relaxed text-apple-text-secondary">
        {description}
      </p>

      <div class="mt-20 space-y-6" data-track-modules data-track-slug={track}>
        {
          moduleOrder.map(({ key, title: moduleTitle, items }) => {
            const count = items.length;
            const countLabel = t(
              count === 1
                ? 'trackPage.moduleLessonCountSingular'
                : 'trackPage.moduleLessonCountPlural',
              locale,
              { count },
            );
            return (
              <details
                open
                class="track-module group/module border-t border-apple-border/70 [&:last-child]:border-b"
                data-module-key={key}
              >
                <summary class="track-module-summary flex cursor-pointer list-none items-baseline justify-between gap-4 py-5 transition-colors duration-200 hover:text-apple-text motion-reduce:transition-none">
                  <span class="flex items-baseline gap-3">
                    <svg
                      aria-hidden="true"
                      viewBox="0 0 16 16"
                      class="track-module-chevron h-3 w-3 flex-shrink-0 self-center transition-transform duration-300 motion-reduce:transition-none"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="4,6 8,10 12,6" />
                    </svg>
                    <span class="text-xl font-semibold tracking-tight text-apple-text">
                      {moduleTitle}
                    </span>
                  </span>
                  <span class="text-sm text-apple-text-secondary">{countLabel}</span>
                </summary>
                <ol class="divide-y divide-apple-border/70 border-t border-apple-border/70 pl-6">
                  {items.map((lesson) => (
                    <li>
                      <a
                        href={localizedLessonHref(stripLocaleSlug(lesson.slug), locale)}
                        class="group flex items-baseline justify-between gap-6 py-5 transition-colors duration-300 hover:text-apple-blue motion-reduce:transition-none"
                      >
                        <span class="flex items-baseline gap-5">
                          <span class="font-mono text-sm text-apple-text-secondary">
                            {String(lesson.data.order).padStart(2, '0')}
                          </span>
                          <span class="text-lg font-medium tracking-tight">
                            {lesson.data.title}
                          </span>
                        </span>
                        <span class="text-sm text-apple-text-secondary">
                          {lesson.data.duration} {t('trackPage.minutesShort', locale)}
                        </span>
                      </a>
                    </li>
                  ))}
                </ol>
              </details>
            );
          })
        }
      </div>
    </main>

    <footer class="border-t border-apple-border/60 py-10">
      <div class="mx-auto max-w-6xl px-6 text-center text-sm text-apple-text-secondary">
        {t('footer.text', locale)}
      </div>
    </footer>

    <style is:global>
      .track-module > summary { list-style: none; }
      .track-module > summary::-webkit-details-marker { display: none; }
      .track-module:not([open]) .track-module-chevron {
        transform: rotate(-90deg);
      }
    </style>

    <script is:inline>
      (function () {
        var container = document.querySelector('[data-track-modules]');
        if (!container) return;
        var trackSlug = container.getAttribute('data-track-slug') || 'default';
        var storageKey = 'hciw:track:' + trackSlug + ':modules';

        function readState() {
          try {
            var raw = localStorage.getItem(storageKey);
            if (!raw) return {};
            var parsed = JSON.parse(raw);
            return (parsed && typeof parsed === 'object') ? parsed : {};
          } catch (_) {
            return {};
          }
        }

        function writeState(state) {
          try {
            localStorage.setItem(storageKey, JSON.stringify(state));
          } catch (_) {
            /* private mode — toggle still works for the session */
          }
        }

        var state = readState();
        var modules = container.querySelectorAll('details.track-module');
        modules.forEach(function (m) {
          var key = m.getAttribute('data-module-key');
          if (!key) return;
          if (state[key] === true) m.removeAttribute('open');
          else if (state[key] === false) m.setAttribute('open', '');
          m.addEventListener('toggle', function () {
            state[key] = !m.open;
            writeState(state);
          });
        });
      })();
    </script>
  </body>
</html>

---
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import ThemeBoot from '../../components/ThemeBoot.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import {
  localizedAboutHref,
  localizedRootHref,
  localizedTrackHref,
  t,
  type Locale,
} from '../../i18n';

const locale: Locale = 'de';
---

<!doctype html>
<html lang={locale} class="bg-apple-bg text-apple-text antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t('about.metaDescription', locale)} />
    <title>{t('about.title', locale)}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeBoot />
  </head>
  <body class="min-h-screen font-sans">
    <header class="border-b border-apple-border/60 bg-apple-bg/80 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href={localizedRootHref(locale)} class="text-base font-semibold tracking-tight text-apple-text">
          {t('nav.home', locale)}
        </a>
        <div class="flex items-center gap-6">
          <a
            href={localizedAboutHref(locale)}
            aria-current="page"
            class="text-sm font-medium text-apple-text"
          >
            {t('nav.about', locale)}
          </a>
          <LanguageSwitcher currentLocale={locale} currentPath={Astro.url.pathname} />
          <ThemeToggle locale={locale} />
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-2xl px-6 pt-24 pb-24">
      <div class="flex justify-center">
        <img
          src="/images/sascha.jpeg"
          alt="Portrait of the author"
          width="200"
          height="200"
          loading="eager"
          class="h-[140px] w-[140px] rounded-full object-cover shadow-md shadow-black/5 ring-1 ring-apple-border sm:h-[200px] sm:w-[200px]"
        />
      </div>

      <h1 class="mt-20 text-center text-4xl font-semibold tracking-tight md:text-5xl">
        TODO: Übersetzen
      </h1>

      <p class="mt-12 text-xl font-light leading-relaxed text-apple-text">
        <em>
          Diese Seite wird übersetzt. <a href="/about" class="text-apple-blue no-underline hover:underline">In English lesen</a>
        </em>
      </p>

      <div class="mt-16 border-t border-apple-border pt-8">
        <div class="flex flex-col gap-3 text-base sm:flex-row sm:justify-between">
          <a
            href={localizedTrackHref('it-basics', locale)}
            class="text-apple-blue no-underline hover:underline"
          >
            {t('about.startWithItBasics', locale)}
          </a>
          <a
            href={localizedRootHref(locale)}
            class="text-apple-blue no-underline hover:underline"
          >
            {t('about.backToHome', locale)}
          </a>
        </div>
      </div>
    </main>

    <footer class="border-t border-apple-border/60 py-10">
      <div class="mx-auto max-w-6xl px-6 text-center text-sm text-apple-text-secondary">
        {t('footer.text', locale)}
      </div>
    </footer>
  </body>
</html>

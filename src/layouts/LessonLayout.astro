---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import LessonNav from '../components/LessonNav.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ThemeBoot from '../components/ThemeBoot.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import {
  localizedAboutHref,
  localizedLessonHref,
  localizedRootHref,
  localizedTrackHref,
  stripLocaleSlug,
  t,
  type Locale,
} from '../i18n';

type Lesson = CollectionEntry<'lessons'>;

interface Props {
  lesson: Lesson;
  siblings: Lesson[];
  prev: Lesson | null;
  next: Lesson | null;
  headings: MarkdownHeading[];
  locale: Locale;
}

const { lesson, siblings, prev, next, headings, locale } = Astro.props as Props;
const { title, duration, objectives, track, module: moduleName, order } = lesson.data;

const trackKeyMap = {
  'it-basics': 'track.itBasics.title',
  'artificial-intelligence': 'track.ai.title',
  'programming': 'track.programming.title',
} as const;

const trackLabel = t(trackKeyMap[track], locale);
const trackHref = localizedTrackHref(track, locale);

// Group sibling lessons by module for the sidebar — same approach as the track page.
const grouped = siblings.reduce<Record<string, Lesson[]>>((acc, l) => {
  const key = l.data.module ?? '_general';
  (acc[key] ||= []).push(l);
  return acc;
}, {});
const moduleOrder = Object.entries(grouped)
  .map(([key, items]) => ({ key, firstOrder: items[0].data.order, items }))
  .sort((a, b) => a.firstOrder - b.firstOrder);

const moduleLabels: Record<string, string> = {
  'hardware-basics': t('trackPage.moduleHardwareBasics', locale),
  '_general': t('trackPage.moduleGeneral', locale),
};

// Right-rail outline: H2s only. The rail is omitted entirely when there are none.
const outline = headings.filter((h) => h.depth === 2);

const siteName = t('nav.home', locale);
const aboutLabel = t('nav.about', locale);
const homeHref = localizedRootHref(locale);
const aboutHref = localizedAboutHref(locale);
const prevRawSlug = prev ? stripLocaleSlug(prev.slug) : null;
const nextRawSlug = next ? stripLocaleSlug(next.slug) : null;
---

<!doctype html>
<html lang={locale} class="bg-apple-bg text-apple-text antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${t('lesson.lessonNumber', locale)} ${order}: ${title}`} />
    <title>{title} — {siteName}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeBoot />
  </head>
  <body class="min-h-screen font-sans">
    <header class="sticky top-0 z-20 border-b border-apple-border/60 bg-apple-bg/80 backdrop-blur">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href={homeHref} class="text-base font-semibold tracking-tight text-apple-text">
          {siteName}
        </a>
        <div class="flex items-center gap-6">
          <a
            href={trackHref}
            class="text-sm text-apple-text-secondary transition-colors duration-300 hover:text-apple-text motion-reduce:transition-none"
          >
            {trackLabel}
          </a>
          <a
            href={aboutHref}
            class="text-sm text-apple-text-secondary transition-colors duration-300 hover:text-apple-text motion-reduce:transition-none"
          >
            {aboutLabel}
          </a>
          <LanguageSwitcher currentLocale={locale} currentPath={Astro.url.pathname} />
          <ThemeToggle locale={locale} />
        </div>
      </nav>
    </header>

    <div class="mx-auto max-w-7xl px-6 py-12 lg:py-16">
      <!--
        Mobile lesson nav. <details> works without JS — keeps the strict CSP intact.
        Hidden on md+ where the sticky sidebar takes over.
      -->
      <details class="lesson-nav-mobile mb-8 rounded-xl border border-apple-border bg-apple-surface md:hidden">
        <summary class="cursor-pointer px-5 py-4 text-sm font-medium text-apple-text">
          <span class="flex items-center justify-between">
            <span>{t('lesson.lessonsInTrack', locale, { track: trackLabel })}</span>
            <span aria-hidden="true" class="text-apple-text-secondary">▾</span>
          </span>
        </summary>
        <div class="border-t border-apple-border/70 px-5 py-4">
          <LessonNav
            moduleOrder={moduleOrder}
            currentSlug={lesson.slug}
            moduleLabels={moduleLabels}
            locale={locale}
          />
        </div>
      </details>

      <div
        id="lesson-grid"
        data-sidebar-collapsed="false"
        class="lesson-grid grid grid-cols-1 gap-12 md:grid-cols-[240px_minmax(0,1fr)] lg:grid-cols-[240px_minmax(0,1fr)_200px] lg:gap-16"
      >
        <!--
          LEFT: sticky lesson nav (md+).
          The grid column width and the inner content's visibility are
          controlled by `data-sidebar-collapsed` on the grid above; see the
          <style> block at the bottom of this layout.
        -->
        <aside class="hidden md:block">
          <div class="sticky top-24">
            <button
              type="button"
              data-sidebar-toggle
              aria-controls="lesson-sidebar-content"
              aria-expanded="true"
              aria-label={t('lesson.collapseSidebar', locale)}
              class="lesson-sidebar-toggle mb-4 inline-flex h-8 w-8 items-center justify-center rounded-md text-apple-text-secondary transition-colors duration-200 hover:bg-apple-surface hover:text-apple-text focus:outline-none focus-visible:ring-2 focus-visible:ring-apple-blue focus-visible:ring-offset-2 motion-reduce:transition-none"
            >
              <svg
                aria-hidden="true"
                viewBox="0 0 20 20"
                class="lesson-sidebar-chevron h-4 w-4 transition-transform duration-300 motion-reduce:transition-none"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <!-- Chevron points left when expanded ("collapse me"); CSS
                     rotates it 180° when collapsed so it points right. -->
                <polyline points="12,4 6,10 12,16" />
              </svg>
            </button>
            <div
              id="lesson-sidebar-content"
              class="lesson-sidebar-content transition-opacity duration-300 motion-reduce:transition-none"
            >
              <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-apple-text-secondary">
                {trackLabel}
              </p>
              <LessonNav
                moduleOrder={moduleOrder}
                currentSlug={lesson.slug}
                moduleLabels={moduleLabels}
                locale={locale}
              />
            </div>
          </div>
        </aside>

        <!-- CENTER: lesson content -->
        <article class="min-w-0">
          <p class="mb-4 text-sm text-apple-text-secondary">
            {moduleName ? `${moduleLabels[moduleName] ?? moduleName} · ${t('lesson.lessonNumber', locale)} ${order}` : `${t('lesson.lessonNumber', locale)} ${order}`}
            <span class="mx-2 text-apple-border">·</span>
            {duration} {t('lesson.duration', locale)}
          </p>
          <h1 class="mb-10 text-4xl font-bold leading-[1.1] tracking-tight sm:text-5xl">
            {title}
          </h1>

          <section class="mb-12 border-l-2 border-apple-blue/60 pl-6">
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-apple-text-secondary">
              {t('lesson.objectives', locale)}
            </p>
            <ul class="space-y-1.5 text-base text-apple-text">
              {objectives.map((obj) => <li>{obj}</li>)}
            </ul>
          </section>

          <div
            class="prose prose-slate max-w-none dark:prose-invert
                   prose-headings:font-semibold prose-headings:tracking-tight
                   prose-h2:mt-16 prose-h2:text-3xl
                   prose-h3:mt-10 prose-h3:text-xl
                   prose-p:text-[1.0625rem] prose-p:leading-[1.7] prose-p:text-apple-text
                   prose-a:text-apple-blue prose-a:no-underline hover:prose-a:underline
                   prose-strong:text-apple-text prose-strong:font-semibold
                   prose-blockquote:border-apple-blue prose-blockquote:not-italic
                   prose-blockquote:font-normal prose-blockquote:text-apple-text"
          >
            <slot />
          </div>

          <!-- Prev/next nav -->
          <nav
            aria-label={t('lesson.lessonNavAriaLabel', locale)}
            class="mt-20 grid gap-4 border-t border-apple-border/70 pt-10 sm:grid-cols-2"
          >
            {
              prev && prevRawSlug ? (
                <a
                  href={localizedLessonHref(prevRawSlug, locale)}
                  class="rounded-2xl border border-apple-border bg-apple-surface p-6 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.05)] motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                >
                  <p class="text-xs font-semibold uppercase tracking-widest text-apple-text-secondary">
                    {t('lesson.previous', locale)}
                  </p>
                  <p class="mt-2 text-base font-medium tracking-tight text-apple-text">
                    {prev.data.title}
                  </p>
                </a>
              ) : (
                <a
                  href={trackHref}
                  class="rounded-2xl border border-apple-border bg-apple-surface p-6 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.05)] motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                >
                  <p class="text-xs font-semibold uppercase tracking-widest text-apple-text-secondary">
                    {t('lesson.back', locale)}
                  </p>
                  <p class="mt-2 text-base font-medium tracking-tight text-apple-text">
                    {t('lesson.trackOverview', locale, { track: trackLabel })}
                  </p>
                </a>
              )
            }
            {
              next && nextRawSlug ? (
                <a
                  href={localizedLessonHref(nextRawSlug, locale)}
                  class="rounded-2xl border border-apple-border bg-apple-surface p-6 text-right transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.05)] motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                >
                  <p class="text-xs font-semibold uppercase tracking-widest text-apple-text-secondary">
                    {t('lesson.next', locale)}
                  </p>
                  <p class="mt-2 text-base font-medium tracking-tight text-apple-text">
                    {next.data.title}
                  </p>
                </a>
              ) : (
                <a
                  href={trackHref}
                  class="rounded-2xl border border-apple-border bg-apple-surface p-6 text-right transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.05)] motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                >
                  <p class="text-xs font-semibold uppercase tracking-widest text-apple-text-secondary">
                    {t('lesson.finish', locale)}
                  </p>
                  <p class="mt-2 text-base font-medium tracking-tight text-apple-text">
                    {t('lesson.backToTrack', locale, { track: trackLabel })}
                  </p>
                </a>
              )
            }
          </nav>
        </article>

        <!-- RIGHT: optional outline rail (lg+) -->
        {
          outline.length > 0 && (
            <aside class="hidden lg:block">
              <div class="sticky top-24">
                <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-apple-text-secondary">
                  {t('lesson.onThisPage', locale)}
                </p>
                <ul class="space-y-2 border-l border-apple-border/70 text-sm">
                  {outline.map((h) => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        class="-ml-px block border-l border-transparent pl-4 leading-snug text-apple-text-secondary transition-colors duration-300 hover:border-apple-blue hover:text-apple-text motion-reduce:transition-none"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </aside>
          )
        }
      </div>
    </div>

    <footer class="border-t border-apple-border/60 py-10">
      <div class="mx-auto max-w-7xl px-6 text-center text-sm text-apple-text-secondary">
        {t('footer.text', locale)}
      </div>
    </footer>

    <style is:global>
      /* Hide the default disclosure triangle on the mobile lesson-nav <details>. */
      .lesson-nav-mobile > summary { list-style: none; }
      .lesson-nav-mobile > summary::-webkit-details-marker { display: none; }

      /*
        Collapsible lesson sidebar.
        When the grid is marked collapsed, the left column shrinks to a
        thin strip just wide enough for the toggle button, and the sidebar
        content (track label + nav) fades out. The grid-template-columns
        transition is supported in modern Chromium / Safari; older browsers
        fall back to an instant snap.
      */
      @media (min-width: 768px) {
        .lesson-grid {
          transition: grid-template-columns 300ms ease;
        }
        .lesson-grid[data-sidebar-collapsed="true"] {
          grid-template-columns: 40px minmax(0, 1fr);
        }
      }
      @media (min-width: 1024px) {
        .lesson-grid[data-sidebar-collapsed="true"] {
          grid-template-columns: 40px minmax(0, 1fr) 200px;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .lesson-grid { transition: none; }
      }

      .lesson-grid[data-sidebar-collapsed="true"] .lesson-sidebar-content {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }
      .lesson-grid[data-sidebar-collapsed="true"] .lesson-sidebar-chevron {
        transform: rotate(180deg);
      }
    </style>

    <script
      is:inline
      data-i18n-collapse={t('lesson.collapseSidebar', locale)}
      data-i18n-expand={t('lesson.expandSidebar', locale)}
    >
      // Apply persisted sidebar state pre-paint, then bind the toggle.
      (function () {
        var grid = document.getElementById('lesson-grid');
        if (!grid) return;
        var script = document.currentScript;
        var i18nCollapse = script
          ? script.getAttribute('data-i18n-collapse')
          : 'Collapse lesson sidebar';
        var i18nExpand = script
          ? script.getAttribute('data-i18n-expand')
          : 'Expand lesson sidebar';

        function readState() {
          try {
            return localStorage.getItem('hciw:sidebar:collapsed') === 'true';
          } catch (_) {
            return false;
          }
        }

        function applyState(collapsed) {
          grid.setAttribute('data-sidebar-collapsed', collapsed ? 'true' : 'false');
          var btns = grid.querySelectorAll('button[data-sidebar-toggle]');
          btns.forEach(function (btn) {
            btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
            btn.setAttribute('aria-label', collapsed ? i18nExpand : i18nCollapse);
          });
        }

        applyState(readState());

        grid.addEventListener('click', function (e) {
          var target = e.target;
          var btn = target && target.closest && target.closest('button[data-sidebar-toggle]');
          if (!btn) return;
          var next = grid.getAttribute('data-sidebar-collapsed') !== 'true';
          applyState(next);
          try {
            localStorage.setItem('hciw:sidebar:collapsed', next ? 'true' : 'false');
          } catch (_) {
            /* private mode — toggle still works for the session */
          }
        });
      })();
    </script>
  </body>
</html>
